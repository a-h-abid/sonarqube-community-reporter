# ==============================================================================
# SonarQube Report Tool — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ==============================================================================

# --- SonarQube Connection ---------------------------------------------------
# Base URL of your SonarQube instance (no trailing slash)
SONAR_URL=http://localhost:9000

# Authentication token (generate at: SonarQube → My Account → Security → Tokens)
SONAR_TOKEN=

# --- Project ----------------------------------------------------------------
# SonarQube project key to generate the report for
SONAR_PROJECT_KEY=

# Branch name (leave empty for the main branch)
SONAR_BRANCH=

# --- Analysis Polling -------------------------------------------------------
# Compute Engine task ID (optional — extracted from .scannerwork/report-task.txt)
SONAR_TASK_ID=

# Seconds between poll attempts when waiting for analysis completion
POLL_INTERVAL=5

# Maximum seconds to wait before timing out
POLL_TIMEOUT=300

# --- Report Output ----------------------------------------------------------
# Comma-separated list of formats: json,md,html,pdf
REPORT_FORMATS=json,md,html,pdf

# Directory where reports are saved (relative or absolute)
REPORT_OUTPUT_DIR=./reports

# --- PostgreSQL (used by docker-compose.yml) --------------------------------
POSTGRES_USER=sonar
POSTGRES_PASSWORD=sonar_password
POSTGRES_DB=sonarqube
